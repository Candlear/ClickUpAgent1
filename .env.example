# Copy to .env for local use only; never commit .env. On Railway, set Variables in the dashboard.

# --- Required for /agent (Gemini) ---
GEMINI_API_KEY=

# --- MCP mode: hosted | community_stdio ---
CLICKUP_MCP_MODE=hosted

# --- Hosted ClickUp MCP (OAuth) ---
CLICKUP_MCP_URL=https://mcp.clickup.com/mcp
# Must match your public HTTPS URL + /oauth/callback (Railway domain or custom domain)
OAUTH_REDIRECT_URI=https://YOUR_SERVICE.up.railway.app/oauth/callback
# Mount a Railway volume on /data and point here for persistent tokens across deploys
CLICKUP_OAUTH_TOKEN_PATH=/data/clickup_oauth.json
# Optional: Fernet key from cryptography; if set, token file is encrypted on disk
# CLICKUP_OAUTH_ENCRYPTION_KEY=
# Optional OAuth scope string if your IdP requires it
# CLICKUP_OAUTH_SCOPE=
# OAUTH_CLIENT_NAME=Langdock ClickUp Proxy
# OAUTH_FLOW_TIMEOUT_S=300

# --- Community MCP (stdio + npx) — only if CLICKUP_MCP_MODE=community_stdio ---
# CLICKUP_API_KEY=
# CLICKUP_TEAM_ID=
# CLICKUP_MCP_NPX_PACKAGE=@taazkareem/clickup-mcp-server
# CLICKUP_MCP_NPX_ARGS=

# --- Webhook security (set on Railway; Langdock must send the same value) ---
LANGDOCK_WEBHOOK_SECRET=

# --- Production guard: if ENVIRONMENT or RAILWAY_ENVIRONMENT is production, LANGDOCK_WEBHOOK_SECRET must be set or /agent returns 503 ---
# ENVIRONMENT=production

# --- Optional tuning ---
# GEMINI_MODEL=gemini-2.0-flash
# AGENT_REQUEST_TIMEOUT_S=120
# MAX_AGENT_STEPS=8
# AGENT_RATE_LIMIT=30/minute
# MCP_RECONNECT_BACKOFF_S=2
# MCP_RECONNECT_MAX_ATTEMPTS=3

# --- After first Railway deploy (hosted): open in browser once ---
# https://YOUR_SERVICE.up.railway.app/oauth/start
# Then verify: GET https://YOUR_SERVICE.up.railway.app/ready  (ready: true)

# --- Test POST /agent (replace HOST and secret) ---
# curl -sS -X POST "https://YOUR_SERVICE.up.railway.app/agent" \
#   -H "Content-Type: application/json" \
#   -H "Authorization: Bearer YOUR_LANGDOCK_WEBHOOK_SECRET" \
#   -d '{"message":"Hello"}'
